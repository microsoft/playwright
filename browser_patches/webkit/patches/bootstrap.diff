+    GtkWidget* parent = GTK_WIDGET(gtk_widget_get_root(m_page->viewWidget()));
+    if (widgetIsOnscreenToplevelWindow(parent))
+        gtk_window_present(GTK_WINDOW(parent));
+    else
+        error = "The view is not on screen"_s;
+}
+
+} // namespace WebKit
