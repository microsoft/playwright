# Playwright local development environment variables.
# Copy this file to .env (which is gitignored) and fill in the values you need.
# Usage: dotenv is loaded automatically by tests/library/playwright.config.ts
#        and tests/playwright-test/playwright.config.ts

# ---------------------------------------------------------------------------
# Browser executable overrides
# Use these to test against a custom/locally compiled browser build.
# ---------------------------------------------------------------------------
CRPATH=
FFPATH=
WKPATH=

# ---------------------------------------------------------------------------
# Test mode
# PWTEST_MODE: default | service | service2
# ---------------------------------------------------------------------------
PWTEST_MODE=default

# PWTEST_CHANNEL: e.g. chrome | msedge | chromium-tip-of-tree | webkit-wsl
PWTEST_CHANNEL=

# Record a video for every test run (slows down execution).
PWTEST_VIDEO=

# Collect a Playwright trace for every test (enables Trace Viewer debugging).
# Set to 1 to activate. Use `npm run test:debug` which sets this automatically.
PWTEST_TRACE=

# ---------------------------------------------------------------------------
# Playwright Service (service / service2 modes)
# ---------------------------------------------------------------------------
PLAYWRIGHT_SERVICE_URL=
PLAYWRIGHT_SERVICE_ACCESS_KEY=
PLAYWRIGHT_SERVICE_OS=linux
PLAYWRIGHT_SERVICE_RUN_ID=

# ---------------------------------------------------------------------------
# Debug helpers
# ---------------------------------------------------------------------------
# Print verbose output from child processes spawned during tests.
PWTEST_DEBUG=

# Open the Playwright Inspector for every test action (headed mode required).
PWDEBUG=

# Open the HTML report automatically after a test run (non-CI only).
# PWTEST_OPEN_REPORT=1
